# Git LFS — vídeos e áudios grandes são versionados via Large File Storage.
# (O A_Onda.mp4 tem 139 MB e estoura o limite de 100 MB/arquivo do GitHub;
#  o resto é pequeno mas vai junto pra manter o histórico git leve.)
*.mp4  filter=lfs diff=lfs merge=lfs -text
*.avi  filter=lfs diff=lfs merge=lfs -text
*.mpeg filter=lfs diff=lfs merge=lfs -text
*.mpg  filter=lfs diff=lfs merge=lfs -text
*.mp3  filter=lfs diff=lfs merge=lfs -text
*.wav  filter=lfs diff=lfs merge=lfs -text
*.ogg  filter=lfs diff=lfs merge=lfs -text

# Normalização de fim de linha em fontes
*.ncl  text
*.lua  text
*.md   text
