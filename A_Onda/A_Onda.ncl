<?xml version="1.0" encoding="ISO-8859-1"?>
<!-- Generated by NCL Eclipse -->
<!-- Trabalho da disciplina Fudamentos de Sistemas Multimidia, semestre 2010.2
     PUC-Rio, Brasil-->

<ncl id="A_Onda" xmlns="http://www.ncl.org.br/NCL3.0/EDTVProfile">
    <head>
        <ruleBase>
            <rule id="en" var="system.language" value="en" comparator="eq" />

            <!-- Faixa do CEP: 30000-000 a 39999-999 -->
            <rule id="BH" var="user.location" comparator="eq" value="30000000"/>
<!--            <compositeRule id="BH-range" operator="and">
                <rule id="BH-gte" var="user.location" comparator="gte" value="30000000"/>
                <rule id="BH-lte" var="user.location" comparator="lte" value="39999999"/>
            </compositeRule>
-->
            <!-- Faixa do CEP: 20000-000 a 28999-999 -->
<!--            <rule id="RJ" var="user.location" comparator="eq" value="20000000"/>
            <compositeRule id="RJ-range" operator="and">
                <rule id="RJ-gte" var="user.location" comparator="gte" value="20000000"/>
                <rule id="RJ-lte" var="user.location" comparator="lte" value="28999999"/>
            </compositeRule>
-->
            <!-- Faixa do CEP: 01000-000 a 19999-999 -->
            <rule id="SP" var="user.location" comparator="gte" value="01000001"/>
<!--            <compositeRule id="SP-range" operator="and">
                <rule id="SP-gte" var="user.location" comparator="gte" value="01000000"/>
                <rule id="SP-lte" var="user.location" comparator="lte" value="19999000"/>
            </compositeRule>
-->
            <rule id="interact" var="system.interactivity" value="true" comparator="eq" />

            <rule id="rCtxCandiru" var="service.ctxChoice" comparator="eq" value="111" />
            <rule id="rCtxMenu" var="service.ctxChoice" comparator="eq" value="112" />

            <rule id="rSwitchCtxMenu-Lendas" var="service.ctxChoice" value="1111" comparator="eq" />
            <rule id="rMenuSwitchCtxMenu-Lenda1" var="service.ctxChoice" value="11111" comparator="eq" />
            <rule id="rMenuSwitchCtxMenu-Lenda2" var="service.ctxChoice" value="11112" comparator="eq" />
            <rule id="rMenuSwitchCtxMenu-Lenda3" var="service.ctxChoice" value="11113" comparator="eq" />

            <rule id="rSwitchCtxMenu-Especies" var="service.ctxChoice" value="1112" comparator="eq" />
            <rule id="rSwitchCtxMenu-Especie1" var="service.ctxChoice" value="11121" comparator="eq" />
            <rule id="rSwitchCtxMenu-Especie2" var="service.ctxChoice" value="11122" comparator="eq" />
            <rule id="rSwitchCtxMenu-Especie3" var="service.ctxChoice" value="11123" comparator="eq" />

            <rule id="rSwitchCtxMenu-Pacotes" var="service.ctxChoice" value="1113" comparator="eq" />
            <rule id="rSwitchCtxMenu-Pacote1" var="service.ctxChoice" value="11131" comparator="eq" />
            <rule id="rSwitchCtxMenu-Pacote2" var="service.ctxChoice" value="11132" comparator="eq" />
            <rule id="rSwitchCtxMenu-Pacote3" var="service.ctxChoice" value="11133" comparator="eq" />
        </ruleBase>

        <transitionBase>
            <transition id="transInFade" type="fade" dur="1s" />
            <transition id="transOutFade" type="fade" dur="1s" />
        </transitionBase>

        <regionBase>
            <!-- Screen Region-->
            <region id="backgroundReg" width="100%" height="100%" zIndex="1" />

            <region id = "screenReg" width = "100%" height = "100%" zIndex = "2">
                <!-- Information region - SYNC1, SYNC2 and SYNC3-->
                <region id = "interactivityReg" right = "10%" top = "10%" width = "20%" height = "10%" zIndex = "3" />
                <region id = "backReg" left = "28%" top = "43%" width = "10%" height = "7%" zIndex = "3" />
                <region id = "cancelReg" right = "3%" bottom = "40%" width = "16%" height = "8%" zIndex = "3" />

                <!-- Menu region, must be seen ESMAECENDO - SYNC5 -->
                <region id = "menu1Reg" left = "5%" top = "10%" width ="20%" height = "30%" zIndex = "3">
                    <region id = "menu1_1Reg" left="0%" top="0%" width="100%" height = "30%" />
                    <region id = "menu1_2Reg" left="0%" top="35%" width="100%" height = "30%" />
                    <region id = "menu1_3Reg" left="0%" top="70%" width="100%" height = "30%" />
                </region>

                <!-- Menu region, must be seen ESMAECENDO - SYNC5 -->
                <region id="menu2RegArc" left="24%" top="7%" width="25%" height="36%" zIndex="3"/>

                <region id="menu2Reg" left="28%" top="10%" width="20%" height="30%" zIndex="4">
                    <region id = "menu2_1Reg" left="0%" top="0%" width="100%" height="30%" />
                    <region id = "menu2_2Reg" left="0%" top="35%" width="100%" height="30%" />
                    <region id = "menu2_3Reg" left="0%" top="70%" width="100%" height="30%" />
                </region>

                <!-- Quiz region -->
                <region id="rgLua" right="0" bottom="0" width="60%"  height="55%" zIndex="2" />
            </region>
        </regionBase>

        <!-- Multiple devices regions -->

        <!-- Active Class -->
        <regionBase device="systemScreen(2)">
            <region id="activeDeviceReg" width="100%" height="100%" zIndex="1" />
        </regionBase>

        <descriptorBase>
            <!-- Background Descriptor -->
            <descriptor id="backgroundDesc" region="backgroundReg" />

            <!-- Screen Descriptor -->
            <descriptor id = "screenDesc" region = "screenReg" />

            <descriptor id="creditosDesc" />

            <!-- Information Descriptors -->
            <descriptor id="interactivitDesc" 
                        transIn="transInFade"
                        region = "interactivityReg"
                        explicitDur="15s"
            />

            <descriptor id="backDesc"
                        transIn="transInFade"
                        region="backReg"
            />

            <descriptor id="cancelDesc"
                        transIn="transInFade"
                        region="cancelReg"
            />

            <!-- Advertisement Descriptors -->
            <descriptor id="advertDesc" 
                        transIn="transInFade"
                        transOut="transOutFade"
                        explicitDur="10s"
            />

            <!-- Menu Descriptors -->
            <descriptor id = "menuDesc" region = "menu1Reg" />

            <!-- Primeiro Nivel do Menu -->
            <descriptor id="menu1_1Desc"
                        transIn="transInFade"
                        region="menu1_1Reg"
                        focusIndex="1" moveUp="3" moveDown="2"
                        focusSrc="media/img/menu/menuLendasFoco.png"
                        focusSelSrc="media/img/menu/menuLendasSel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menu1_2Desc"
                        transIn="transInFade"
                        region="menu1_2Reg"
                        focusIndex="2" moveUp="1" moveDown="3"
                        focusSrc="media/img/menu/menuEspeciesFoco.png"
                        focusSelSrc="media/img/menu/menuEspeciesSel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menu1_3Desc"
                        transIn="transInFade"
                        region="menu1_3Reg"
                        focusIndex="3" moveUp="2" moveDown="1"
                        focusSrc="media/img/menu/menuTurismoFoco.png"
                        focusSelSrc="media/img/menu/menuTurismoSel.png"
                        focusBorderWidth="0"
            />
            <!-- Segundo Nivel do Menu -->

            <!-- Menu Lendas -->
            <descriptor id="menuLendasArcDesc" 
                        transIn="transInFade"
                        region="menu2RegArc" />

            <descriptor id="menuLenda1Desc"
                        transIn="transInFade"
                        region="menu2_1Reg"
                        focusIndex="4" moveUp="6" moveDown="5"
                        focusSrc="media/img/menu/menuLenda01Foco.png"
                        focusSelSrc="media/img/menu/menuLenda01Sel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menuLenda2Desc"
                        transIn="transInFade"
                        region="menu2_2Reg"
                        focusIndex="5" moveUp="4" moveDown="6"
                        focusSrc="media/img/menu/menuLenda02Foco.png"
                        focusSelSrc="media/img/menu/menuLenda02Sel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menuLenda3Desc"
                        transIn="transInFade"
                        region="menu2_3Reg"
                        focusIndex="6" moveUp="5" moveDown="4"
                        focusSrc="media/img/menu/menuLenda03Foco.png"
                        focusSelSrc="media/img/menu/menuLenda03Sel.png"
                        focusBorderWidth="0"
            />

            <!-- Menu Especies -->
            <descriptor id="menuEspeciesArcDesc" 
                        transIn="transInFade"
                        region="menu2RegArc"
            />

            <descriptor id="menuEspecie1Desc"
                        transIn="transInFade"
                        region="menu2_1Reg"
                        focusIndex="7" moveUp="9" moveDown="8"
                        focusSrc="media/img/menu/menuEspecie01Foco.png"
                        focusSelSrc="media/img/menu/menuEspecie01Sel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menuEspecie2Desc"
                        transIn="transInFade"
                        region="menu2_2Reg"
                        focusIndex="8" moveUp="7" moveDown="9"
                        focusSrc="media/img/menu/menuEspecie02Foco.png"
                        focusSelSrc="media/img/menu/menuEspecie02Sel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menuEspecie3Desc"
                        transIn="transInFade"
                        region="menu2_3Reg"
                        focusIndex="9" moveUp="8" moveDown="7"
                        focusSrc="media/img/menu/menuEspecie03Foco.png"
                        focusSelSrc="media/img/menu/menuEspecie03Sel.png"
                        focusBorderWidth="0"
            />

            <!-- Menu Pacotes -->
            <descriptor id="menuTurismoArcDesc" 
                        transIn="transInFade"
                        region="menu2RegArc"
            />

            <descriptor id="menuPacote1Desc"
                        transIn="transInFade"
                        region="menu2_1Reg"
                        focusIndex="10" moveUp="12" moveDown="11"
                        focusSrc="media/img/menu/menuPacote01Foco.png"
                        focusSelSrc="media/img/menu/menuPacote01Sel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menuPacote2Desc"
                        transIn="transInFade"
                        region="menu2_2Reg"
                        focusIndex="11" moveUp="10" moveDown="12"
                        focusSrc="media/img/menu/menuPacote02Foco.png"
                        focusSelSrc="media/img/menu/menuPacote02Sel.png"
                        focusBorderWidth="0"
            />

            <descriptor id="menuPacote3Desc"
                        transIn="transInFade"
                        region="menu2_3Reg"
                        focusIndex="12" moveUp="11" moveDown="10"
                        focusSrc="media/img/menu/menuPacote03Foco.png"
                        focusSelSrc="media/img/menu/menuPacote03Sel.png"
                        focusBorderWidth="0"
            />

            <!-- Decision Descriptor -->
            <descriptor id="dsLua" region="rgLua" focusIndex="13" />

            <!-- Multiple Devices Descriptors -->
            <descriptor id = "activeDeviceDesc" region = "activeDeviceReg" />

        </descriptorBase>

        <!-- Connector Base definition -->
        <connectorBase>
            <importBase documentURI="A_Onda_ConnectorBase.ncl" alias="conExe"/>
        </connectorBase>
    </head>

    <body>
        <!-- Ports -->
        <port id="pVideoPrincipal" component="compVideoAOnda" />

        <!-- Media Components -->
        <media id="background" src="media/img/background/vlcsnap-2010-10-13-11h58m57s159.png" descriptor="backgroundDesc" />

        <media id="compVideoAOnda" src="media/A_Onda.mp4" descriptor="screenDesc">
            <area id="segComercViagem" begin="100s" end="110s" />
            <area id="segMinSaudeVacina" begin="150s" end="160s" />
            <area id="segIntCandiru" begin="350s" end="360s" />
            <area id="segIntMenu" begin="395s" end="415s" />
            <area id="segQuizQuestion" begin="480s" end="490s" />
            <area id="segCreditos" begin="740s" end="750s" />
            <property name="bounds" />
        </media>

        <media id="compImgEstado" src="media/img/amapa/fort_fim_01.jpg" descriptor="advertDesc">
            <property name="right" value="10%" />
            <property name="top" value="5%" />
            <property name="width" value="20%" />
            <property name="height" value="15%" />
            <property name="zIndex" value="3" />
        </media>

        <media id="compTxtVisite" src="media/txt/amapa/estado.txt" descriptor="advertDesc">
            <property name="right" value="10%" />
            <property name="top" value="22%" />
            <property name="width" value="20%" />
            <property name="height" value="5%" />
            <property name="zIndex" value="3" />
            <property name="fontColor" value="white" />
            <property name="fontSize" value="20" />
        </media>

        <media id="compImgMinSaude" src="media/img/saude/logoBrasilSaude.jpg" descriptor="advertDesc">
            <property name="right" value="10%" />
            <property name="top" value="5%" />
            <property name="width" value="15%" />
            <property name="height" value="5%" />
            <property name="zIndex" value="3" />
        </media>

        <media id="compTxtVacina" src="media/txt/saude/saude.txt" descriptor="advertDesc">
            <property name="right" value="10%" />
            <property name="top" value="12%" />
            <property name="width" value="15%" />
            <property name="height" value="5%" />
            <property name="zIndex" value="3" />
            <property name="fontColor" value="white" />
            <property name="fontSize" value="20" />
        </media>

        <media id="compImgInteratividade" src="media/img/interactivity/int_green.png" descriptor="interactivitDesc" />
        <media id="compImgInteratividadeCandiru" src="media/img/interactivity/int_green.png" descriptor="interactivitDesc" />
        <media id="compImgInteratividadeQuiz" src="media/img/interactivity/int_green.png" descriptor="interactivitDesc" />
        <media id="iconMenuCancel" src="media/img/interactivity/int_red.png" descriptor="cancelDesc" />

        <media id="compImgCreditos" src="media/img/creditos/creditos_PUC-Rio.png" descriptor="creditosDesc">
            <property name="right" value="30%" />
            <property name="top" value="30%" />
            <property name="width" value="45%" />
            <property name="height" value="27%" />
            <property name="zIndex" value="3" />
            <property name="explicitDur" value="2s"/>
        </media>

        <!-- Multiple devices - Begin -->
        <media id="activeDeviceCompImgCandiru" src="NCLApplications/A_Onda/A_Onda-Candiru.ncl" descriptor="activeDeviceDesc" />
        <media id="activeDeviceCompCandiruIcon" src="NCLApplications/A_Onda/A_Onda-CandiruIcon.ncl" descriptor="activeDeviceDesc" />

        <media id="activeDeviceCompMenu" src="NCLApplications/A_Onda/A_Onda-Menu.ncl" descriptor="activeDeviceDesc" />
        <media id="activeDeviceCompMenuIcon" src="NCLApplications/A_Onda/A_Onda-MenuIcon.ncl" descriptor="activeDeviceDesc" />
        <!-- Multiple devices  - End -->

        <!-- Switches -->

        <!-- Contexts - Begin -->

        <!-- ctxCandiru - Begin-->
        <context id="ctxCandiru">
            <port id="pMapaCandiru" component="mapaCandiru" />

            <media id="mapaCandiru" src="media/img/candiru/mapaCandiru.jpg">
                <property name="explicitDur" value="10s" />
                <property name="left" value="0%" />
                <property name="top" value="50%" />
                <property name="width" value="50%" />
                <property name="height" value="50%" />
                <property name="zIndex" value="3" />
            </media>

            <media id="candiru01_1" src="media/txt/candiru/candiru01_1.txt">
                <property name="explicitDur" value="10s" />
                <property name="left" value="5%" />
                <property name="top" value="20%" />
                <property name="width" value="40%" />
                <property name="height" value="40%" />
                <property name="zIndex" value="3" />
                <property name="fontColor" value="white" />
                <property name="fontSize" value="20" />
            </media>

            <media id="candiru01_2" src="media/txt/candiru/candiru01_2.txt">
                <property name="explicitDur" value="10s" />
                <property name="right" value="5%" />
                <property name="top" value="60%" />
                <property name="width" value="40%" />
                <property name="height" value="40%" />
                <property name="zIndex" value="3" />
                <property name="fontColor" value="white" />
                <property name="fontSize" value="20" />
            </media>

            <media id="imgCandiru" src="media/img/candiru/imgCandiru.png">
                <property name="explicitDur" value="10s" />
                <property name="left" value="0%" />
                <property name="top" value="50%" />
                <property name="width" value="50%" />
                <property name="height" value="50%" />
                <property name="zIndex" value="3" />
            </media>

            <media id="candiru02_1" src="media/txt/candiru/candiru02_1.txt">
                <property name="explicitDur" value="10s" />
                <property name="left" value="5%" />
                <property name="top" value="10%" />
                <property name="width" value="40%" />
                <property name="height" value="35%" />
                <property name="zIndex" value="3" />
                <property name="fontColor" value="white" />
                <property name="fontSize" value="20" />
            </media>

            <media id="candiru02_2" src="media/txt/candiru/candiru02_2.txt">
                <property name="explicitDur" value="10s" />
                <property name="right" value="5%" />
                <property name="top" value="60%" />
                <property name="width" value="40%" />
                <property name="height" value="40%" />
                <property name="zIndex" value="3" />
                <property name="fontColor" value="white" />
                <property name="fontSize" value="20" />
            </media>

            <link id="lMapaCandiru" xconnector="conExe#onBeginStart">
                <bind role="onBegin" component="mapaCandiru"/>
                <bind role="start" component="candiru01_1"/>
                <bind role="start" component="candiru01_2"/>
            </link>

            <link id="lNextCandiruTxt" xconnector="conExe#onBeginStart">
                <bind role="onBegin" component="imgCandiru"/>
                <bind role="start" component="candiru02_1"/>
                <bind role="start" component="candiru02_2"/>
            </link>

            <link id="lNextCandiruImg" xconnector="conExe#onEndStart">
                <bind role="onEnd" component="mapaCandiru" />
                <bind role="start" component="imgCandiru" />
            </link>

        </context>
        <!-- ctxCandiru - End-->

        <!-- ctxMenu - Begin -->
        <context id="ctxMenu">
            <media id="settingCtxMenu" refer="settingCtx" />

            <port id="pIconMenu1_1" component="iconMenu1_1" />
            <media id="iconMenu1_1" src="media/img/menu/menuLendasOrig.png" descriptor="menu1_1Desc" />

            <port id="pIconMenu1_2" component="iconMenu1_2" />
            <media id="iconMenu1_2" src="media/img/menu/menuEspeciesOrig.png" descriptor="menu1_2Desc" />

            <port id="pIconMenu1_3" component="iconMenu1_3" />
            <media id="iconMenu1_3" src="media/img/menu/menuTurismoOrig.png" descriptor="menu1_3Desc" />

            <!-- Lendas submenu - Begin -->

            <!-- Lenda 01 content - Begin -->
            <media id="iconMenuLenda2_1" src="media/img/menu/menuLenda01Orig.png" descriptor="menuLenda1Desc" />
            <media id="iconMenuLendasSelArc" src="media/img/menu/menuLendasSelArc.png" descriptor="menuLendasArcDesc" />
            <media id="iconMenuBack" src="media/img/menu/voltar.png" descriptor="backDesc" />

            <media id="imgLenda1" src="media/img/lendas/cobra_grande.jpg">
                <property name="left" value="0%" />
                <property name="bottom" value="0%" />
                <property name="width" value="50%" />
                <property name="height" value="50%" />
                <property name="zIndex" value="3" />
            </media>

            <media id="txtLenda1" src="media/txt/lendas/lenda1.txt">
                <property name="right" value="5%" />
                <property name="top" value="60%" />
                <property name="width" value="40%" />
                <property name="height" value="40%" />
                <property name="zIndex" value="3" />
                <property name="fontColor" value="white" />
                <property name="fontSize" value="20" />
            </media>

            <!-- Links -->
            <link id="lBeginLenda1" xconnector="conExe#onBeginStart">
                <bind role="onBegin" component="imgLenda1" />
                <bind role="start" component="txtLenda1" />
            </link>

            <link id="lEndLenda1" xconnector="conExe#onEndStop">
                <bind role="onEnd" component="imgLenda1" />
                <bind role="stop" component="txtLenda1" />
            </link>

            <link id="lIconMenuLenda2_1End" xconnector="conExe#onEndStop">
                <bind role="onEnd" component="iconMenuLenda2_1" />
                <bind role="stop" component="imgLenda1" />
            </link>
            <!-- Lenda 01 content - End -->

            <!-- Lenda 02 content - Begin -->
            <media id="iconMenuLenda2_2" src="media/img/menu/menuLenda02Orig.png" descriptor="menuLenda2Desc" />
            <media id="imgLenda2" src="media/img/lendas/ms_curupira.jpg">
                <property name="left" value="0%" />
                <property name="bottom" value="0%" />
                <property name="width" value="50%" />
                <property name="height" value="50%" />
                <property name="zIndex" value="3" />
            </media>

            <media id="txtLenda2" src="media/txt/lendas/lenda2.txt">
                <property name="right" value="5%" />
                <property name="top" value="60%" />
                <property name="width" value="40%" />
                <property name="height" value="40%" />
                <property name="zIndex" value="3" />
                <property name="fontColor" value="white" />
                <property name="fontSize" value="20" />
            </media>

            <!-- Links -->
            <link id="lBeginLenda2" xconnector="conExe#onBeginStart">
                <bind role="onBegin" component="imgLenda2" />
                <bind role="start" component="txtLenda2" />
            </link>

            <link id="lEndLenda2" xconnector="conExe#onEndStop">
                <bind role="onEnd" component="imgLenda2" />
                <bind role="stop" component="txtLenda2" />
            </link>

            <link id="lIconMenuLenda2_2End" xconnector="conExe#onEndStop">
                <bind role="onEnd" component="iconMenuLenda2_2" />
                <bind role="stop" component="imgLenda2" />
            </link>
            <!-- Lenda 02 content - End -->

            <!-- Lenda 03 content - Begin -->
            <media id="iconMenuLenda2_3" src="media/img/menu/menuLenda03Orig.png" descriptor="menuLenda3Desc" />

            <media id="imgLenda3" src="media/img/lendas/vitoria_regia.jpg">
                <property name="left" value="0%" />
                <property name="bottom" value="0%" />
                <property name="width" value="50%" />
                <property name="height" value="50%" />
                <property name="zIndex" value="3" />
            </media>

            <media id="txtLenda3" src="media/txt/lendas/lenda3.txt">
                <property name="right" value="5%" />
                <property name="top" value="60%" />
                <property name="width" value="40%" />
                <property name="height" value="40%" />
                <property name="zIndex" value="3" />
                <property name="fontColor" value="white" />
                <property name="fontSize" value="20" />
            </media>

            <!-- Links -->
            <link id="lBeginLenda3" xconnector="conExe#onBeginStart">
                <bind role="onBegin" component="imgLenda3" />
                <bind role="start" component="txtLenda3" />
            </link>

            <link id="lEndLenda3" xconnector="conExe#onEndStop">
                <bind role="onEnd" component="imgLenda3" />
                <bind role="stop" component="txtLenda3" />
            </link>

            <link id="lIconMenuLenda2_3End" xconnector="conExe#onEndStop">
                <bind role="onEnd" component="iconMenuLenda2_3" />
                <bind role="stop" component="imgLenda3" />
            </link>
            <!-- Lenda 03 content - End -->

            <!-- Links -->
            <link id="lSwitchCtxMenu-Lendas" xconnector="conExe#onBeginSet">
                <bind role="onBegin" component="iconMenuLenda2_1" />
                <bind role="set" component="settingCtxMenu" interface="service.currentFocus">
                    <bindParam name="var" value="4" />
                </bind>  
            </link>

            <link id="lMenuSwitchCtxMenu-Lenda1" xconnector="conExe#onKeySelectionStopSetStart">
                <bind role="onSelection" component="iconMenuLenda2_1" />

                <bind role="stop" component="imgLenda2"/>
                <bind role="stop" component="imgLenda3"/>

                <bind role="set" component="settingCtxMenu" interface="service.ctxChoice">
                    <bindParam name="var" value="11111" />
                </bind>

