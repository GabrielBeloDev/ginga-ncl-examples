                    <mapping component="refHotel3SPCtx" />
                </switchPort>

                <bindRule constituent="refHotel3BHCtx" rule="BH" />
                <bindRule constituent="refHotel3SPCtx" rule="SP" />
                <defaultComponent component="refHotel3RJCtx" />

                <context id="refHotel3BHCtx" refer="hotel3BHCtx" />
                <context id="refHotel3RJCtx" refer="hotel3RJCtx" />
                <context id="refHotel3SPCtx" refer="hotel3SPCtx" />
            </switch>
            <!-- Switch Turismo Hotel 03 - End -->

            <link id="lIconMenuTurismo3_3End" xconnector="conExe#onEndStop">
                <bind role="onEnd" component="iconMenuTurismo3_3" />
                <bind role="stop" component="switchTurismo-Hotel03" interface="spSwitchTurismo-Hotel03" />
            </link>
            <!-- Pacote 03 content - End -->

            <!-- Link section -->
            <link id="lSwitchCtxMenu-Turismo" xconnector="conExe#onBeginSet">
                <bind role="onBegin" component="iconMenuTurismo3_1" />
                <bind role="set" component="settingCtxMenu" interface="service.currentFocus">
                    <bindParam name="var" value="10" />
                </bind>
            </link>

            <link id="lSwitchCtxMenu-Turismo1" xconnector="conExe#onKeySelectionStopSetStart">
                <bind role="onSelection" component="iconMenuTurismo3_1" />

                <bind role="stop" component="switchTurismo-Hotel02" />
                <bind role="stop" component="switchTurismo-Hotel03" />

                <bind role="set" component="settingCtxMenu" interface="service.ctxChoice">
                    <bindParam name="var" value="11131" />
                </bind>

                <bind role="start" component="switchTurismo-Hotel01" interface="spSwitchTurismo-Hotel01"/>
            </link>

            <link id="lSwitchCtxMenu-Turismo2" xconnector="conExe#onKeySelectionStopSetStart">
                <bind role="onSelection" component="iconMenuTurismo3_2" />

                <bind role="stop" component="switchTurismo-Hotel01" />
                <bind role="stop" component="switchTurismo-Hotel03" />

                <bind role="set" component="settingCtxMenu" interface="service.ctxChoice">
                    <bindParam name="var" value="11132" />
                </bind>

                <bind role="start" component="switchTurismo-Hotel02" interface="spSwitchTurismo-Hotel02"/>
            </link>

            <link id="lSwitchCtxMenu-Turismo3" xconnector="conExe#onKeySelectionStopSetStart">
                <bind role="onSelection" component="iconMenuTurismo3_3" />

                <bind role="stop" component="switchTurismo-Hotel01" />
                <bind role="stop" component="switchTurismo-Hotel02" />

                <bind role="set" component="settingCtxMenu" interface="service.ctxChoice">
                    <bindParam name="var" value="11133" />
                </bind>

                <bind role="start" component="switchTurismo-Hotel03" interface="spSwitchTurismo-Hotel03"/>
            </link>

            <link id="lSwitchCtxMenuEnd-Turismo" xconnector="conExe#onOrKeySelectionStopSet">
                <bind role="onSelection" component="iconMenuTurismo3_1">
                    <bindParam name="keyCode" value="CURSOR_LEFT" />
                </bind>
                <bind role="onSelection" component="iconMenuTurismo3_2">
                    <bindParam name="keyCode" value="CURSOR_LEFT" />
                </bind>
                <bind role="onSelection" component="iconMenuTurismo3_3">
                    <bindParam name="keyCode" value="CURSOR_LEFT" />
                </bind>

                <bind role="stop" component="iconMenuTurismo3_1" />
                <bind role="stop" component="iconMenuTurismo3_2" />
                <bind role="stop" component="iconMenuTurismo3_3" />
                <bind role="stop" component="iconMenuTurismoSelArc"/>
                <bind role="stop" component="iconMenuBack" />

                <bind role="set" component="settingCtxMenu" interface="service.currentFocus">
                    <bindParam name="var" value="3" />
                </bind>
            </link>

            <!-- Turismo submenu - End -->

            <!-- Link section -->

            <link id="lSwitchCtxMenu-LendasBegin" xconnector="conExe#onKeySelectionStopSetStart">
                <bind role="onSelection" component="iconMenu1_1" />
                <bind role="stop" component="iconMenuLenda2_1" />
                <bind role="stop" component="iconMenuLenda2_2" />
                <bind role="stop" component="iconMenuLenda2_3" />
                <bind role="stop" component="iconMenuLendasSelArc" />

                <bind role="stop" component="iconMenuEspecie2_1" />
                <bind role="stop" component="iconMenuEspecie2_2" />
                <bind role="stop" component="iconMenuEspecie2_3" />
                <bind role="stop" component="iconMenuEspeciesSelArc" />

                <bind role="stop" component="iconMenuTurismo3_1" />
                <bind role="stop" component="iconMenuTurismo3_2" />
                <bind role="stop" component="iconMenuTurismo3_3" />
                <bind role="stop" component="iconMenuTurismoSelArc" />

                <bind role="stop" component="iconMenuBack" />

                <bind role="set" component="settingCtxMenu" interface="service.ctxChoice">
                    <bindParam name="var" value="1111" />
                </bind>

                <bind role="start" component="iconMenuLendasSelArc" />
                <bind role="start" component="iconMenuLenda2_1" />
                <bind role="start" component="iconMenuLenda2_2" />
                <bind role="start" component="iconMenuLenda2_3" />

                <bind role="start" component="iconMenuBack" />
            </link>

            <link id="lSwitchCtxMenu-EspeciesBegin" xconnector="conExe#onKeySelectionStopSetStart">
                <bind role="onSelection" component="iconMenu1_2" />
                <bind role="stop" component="iconMenuLenda2_1" />
                <bind role="stop" component="iconMenuLenda2_2" />
                <bind role="stop" component="iconMenuLenda2_3" />
                <bind role="stop" component="iconMenuLendasSelArc" />

                <bind role="stop" component="iconMenuEspecie2_1" />
                <bind role="stop" component="iconMenuEspecie2_2" />
                <bind role="stop" component="iconMenuEspecie2_3" />
                <bind role="stop" component="iconMenuEspeciesSelArc" />

                <bind role="stop" component="iconMenuTurismo3_1" />
                <bind role="stop" component="iconMenuTurismo3_2" />
                <bind role="stop" component="iconMenuTurismo3_3" />
                <bind role="stop" component="iconMenuTurismoSelArc" />

                <bind role="stop" component="iconMenuBack" />

                <bind role="set" component="settingCtxMenu" interface="service.ctxChoice">
                    <bindParam name="var" value="1112" />
                </bind>

                <bind role="start" component="iconMenuEspeciesSelArc" />
                <bind role="start" component="iconMenuEspecie2_1" />
                <bind role="start" component="iconMenuEspecie2_2" />
                <bind role="start" component="iconMenuEspecie2_3" />
                <bind role="start" component="iconMenuBack" />
            </link>

            <link id="lSwitchCtxMenu-TurismoBegin" xconnector="conExe#onKeySelectionStopSetStart">
                <bind role="onSelection" component="iconMenu1_3" />
                <bind role="stop" component="iconMenuLenda2_1" />
                <bind role="stop" component="iconMenuLenda2_2" />
                <bind role="stop" component="iconMenuLenda2_3" />
                <bind role="stop" component="iconMenuLendasSelArc" />

                <bind role="stop" component="iconMenuEspecie2_1" />
                <bind role="stop" component="iconMenuEspecie2_2" />
                <bind role="stop" component="iconMenuEspecie2_3" />
                <bind role="stop" component="iconMenuEspeciesSelArc" />

                <bind role="stop" component="iconMenuTurismo3_1" />
                <bind role="stop" component="iconMenuTurismo3_2" />
                <bind role="stop" component="iconMenuTurismo3_3" />
                <bind role="stop" component="iconMenuTurismoSelArc" />

                <bind role="stop" component="iconMenuBack" />

                <bind role="set" component="settingCtxMenu" interface="service.ctxChoice">
                    <bindParam name="var" value="1113" />
                </bind>

                <bind role="start" component="iconMenuTurismoSelArc" />
                <bind role="start" component="iconMenuTurismo3_1" />
                <bind role="start" component="iconMenuTurismo3_2" />
                <bind role="start" component="iconMenuTurismo3_3" />
                <bind role="start" component="iconMenuBack" />
            </link>
        </context>
        <!-- ctxMenu - End -->

        <!-- ctxNCLuaQuiz - Being-->
        <context id="ctxNCLuaQuiz">
            <port id="pLua" component="lua" />
            <media id="lua" src="media/lua/quiz.lua" descriptor="dsLua" />
        </context>
        <!-- ctxNCLuaQuiz - End -->

        <!-- Contexts - End -->

        <media id="settingCtx" type="application/x-ginga-settings">
            <property name="service.ctxChoice" value="0" />
            <property name="service.currentFocus" value="0" />
            <property name="service.candiruToDevice" value="false" />
            <property name="service.menuToDevice" value="false" />
            <property name="service.viagemToDevice" value="false" />
            <property name="service.currentKeyMaster" value="0" />
        </media>

        <switch id = "switchContexts">
            <bindRule rule="rCtxCandiru" constituent="refCtxCandiru" />
            <bindRule rule="rCtxMenu" constituent="refCtxMenu" />

            <context id="refCtxCandiru" refer="ctxCandiru" />
            <context id="refCtxMenu" refer="ctxMenu" />
        </switch>

        <!-- XLinkConnectors - Part I: Main Context (Body) -->
        <link id="lBeginVideoPrincipal" xconnector="conExe#onBeginStart">
            <bind role="onBegin" component="compVideoAOnda" />
            <bind role="start" component="background" />
        </link>

        <link id="lViagem" xconnector="conExe#onBeginStart">
            <bind role="onBegin" component="compVideoAOnda" interface="segComercViagem" />
            <bind role="start" component="compImgEstado" />
            <bind role="start" component="compTxtVisite" />
        </link>

        <link id="lVacina" xconnector="conExe#onBeginStart">
            <bind role="onBegin" component="compVideoAOnda" interface="segMinSaudeVacina" />
            <bind role="start" component="compImgMinSaude" />
            <bind role="start" component="compTxtVacina" />
        </link>

        <link id="lIntCandiru" xconnector="conExe#onBeginStart">
            <bind role="onBegin" component="compVideoAOnda" interface="segIntCandiru" />
            <bind role="start" component="compImgInteratividadeCandiru" />
            <bind role="start" component="activeDeviceCompCandiruIcon" />
        </link>

        <link id="lInfoCandiru" xconnector="conExe#onKeySelectionStopSetStart">
            <bind role="onSelection" component="compImgInteratividadeCandiru">
                <bindParam name="keyCode" value="GREEN" />
            </bind>

            <bind role="stop" component="compImgInteratividadeCandiru" />

            <bind role="set" component="settingCtx" interface="service.ctxChoice">
                <bindParam name="var" value="111" />
            </bind>

            <bind role="set" component="compVideoAOnda" interface="bounds">
                <bindParam name="var" value="50%, 0%, 50%, 50%" />
            </bind>

            <bind role="start" component="switchContexts" />
        </link>

        <link id="lIntMenu" xconnector="conExe#onBeginStart">
            <bind role="onBegin" component="compVideoAOnda" interface="segIntMenu"/>
            <bind role="start" component="compImgInteratividade"/>
            <bind role="start" component="activeDeviceCompMenuIcon" />
        </link>

        <link id="lActiveDeviceCompCandiruIconEnd" xconnector="conExe#onEndStop" >
            <bind role="onEnd" component="compImgInteratividade" />
            <bind role="stop" component="activeDeviceCompMenuIcon" />
        </link>

        <link id="lCtxMenu" xconnector="conExe#onKeySelectionStopSetStart">
            <bind role="onSelection" component="compImgInteratividade">
                <bindParam name="keyCode" value="GREEN" />
            </bind>

            <bind role="stop" component="compImgInteratividade" />

            <bind role="set" component="settingCtx" interface="service.ctxChoice">
                <bindParam name="var" value="112" />
            </bind>

            <bind role="set" component="compVideoAOnda" interface="bounds">
                <bindParam name="var" value="50%, 0%, 50%, 50%" />
            </bind>

            <bind role="start" component="switchContexts" />
            <bind role="start" component="iconMenuCancel" />
        </link>

        <link id="lIntQuiz" xconnector="conExe#onBeginStart">
            <bind role="onBegin" component="compVideoAOnda" interface="segQuizQuestion" />
            <bind role="start" component="compImgInteratividadeQuiz" />
        </link>

        <link id="lQuizQuestion" xconnector="conExe#onKeySelectionStopSetStart">
            <bind role="onSelection" component="compImgInteratividadeQuiz">
                <bindParam name="keyCode" value="GREEN" />
            </bind>

            <bind role="stop" component="compImgInteratividadeQuiz" />

            <bind role="set" component="settingCtx" interface="service.currentKeyMaster">
                <bindParam name="var" value="13" />
            </bind>

            <bind role="set" component="settingCtx" interface="service.currentFocus">
                <bindParam name="var" value="13" />
            </bind>

            <bind role="start" component="ctxNCLuaQuiz" />
        </link>

        <link id="lQuizQuestionEnd" xconnector="conExe#onEndSet">
            <bind role="onEnd" component="ctxNCLuaQuiz" />

            <bind role="set" component="settingCtx" interface="service.currentKeyMaster">
                <bindParam name="var" value="0" />
            </bind>
        </link>

        <link id="lSwitchCtxMenuEnd" xconnector="conExe#onKeySelectionStop">
            <bind role="onSelection" component="iconMenuCancel">
                <bindParam name="keyCode" value="RED" />
            </bind>

            <bind role="stop" component="switchContexts" />
            <bind role="stop" component="iconMenuCancel" />
         </link>

        <link id="lEndSwitchContexts" xconnector="conExe#onEndSet">
            <bind role="onEnd" component="switchContexts" />

            <bind role="set" component="compVideoAOnda" interface="bounds">
                <bindParam name="var" value="0, 0, 200%, 200%" />
            </bind>
        </link>

        <link id="lStartCandiruOnDevice" xconnector="conExe#onEndAttributionCmpStopStart">
            <bind role="onEndAttribution" component="settingCtx" interface="service.candiruToDevice" />

            <bind role="cmpVal" component="settingCtx" interface="service.candiruToDevice">
                <bindParam name="val" value="true" />
            </bind>

            <bind role="stop" component="switchContexts"/>
            <bind role="stop" component="compImgInteratividadeCandiru" />

            <bind role="start" component="activeDeviceCompImgCandiru" />
        </link>

        <link id="lStartMenuOnDevice" xconnector="conExe#onEndAttributionCmpStopStart">
            <bind role="onEndAttribution" component="settingCtx" interface="service.menuToDevice"/>

            <bind role="cmpVal" component="settingCtx" interface="service.menuToDevice">
                <bindParam name="val" value="true"/>
            </bind>

            <bind role="stop" component="switchContexts"/>
            <bind role="stop" component="compImgInteratividade" />

            <bind role="start" component="activeDeviceCompMenu" />
        </link>

        <link id="lCreditos" xconnector="conExe#onBeginStart">
            <bind role="onBegin" component="compVideoAOnda" interface="segCreditos" />
            <bind role="start" component="compImgCreditos" />
        </link>

        <link id="lEndVideoPrincipal" xconnector="conExe#onEndStop">
            <bind role = "onEnd" component = "compVideoAOnda" />
            <bind role = "stop" component = "compImgEstado" />
            <bind role = "stop" component = "compTxtVisite" />
            <bind role = "stop" component = "compImgMinSaude" />
            <bind role = "stop" component = "compTxtVacina" />
            <bind role = "stop" component = "compImgInteratividade" />
            <bind role = "stop" component = "switchContexts" />
            <bind role = "stop" component = "activeDeviceCompMenu" />
        </link>

    </body>

</ncl>
